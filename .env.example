# PlacementOS Environment Variables
# Copy this to .env in each service folder and fill in values.
# Never commit .env to git.

# ── Resume Screener (resume-screener/.env) ────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...

# ── Mock ERP (no env vars needed for local dev) ──────────────────────────
# ERP_PORT=8001  # default

# ── UiPath Orchestrator Assets (configure in Cloud, not here) ────────────
# Set these as Orchestrator Assets (String/Credential) in your tenant:
#
# ERP_BASE_URL          = https://your-erp-service.onrender.com
# SCREENER_URL          = https://your-screener-service.onrender.com
# SMTP_HOST             = smtp.gmail.com
# SMTP_PORT             = 587
# SMTP_USER             = yourplacementos@gmail.com
# SMTP_PASSWORD         = [store as Credential asset, not plain text]
# GOOGLE_CALENDAR_TOKEN = [store as Credential asset]
