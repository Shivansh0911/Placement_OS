<Activity mc:Ignorable="sap sap2010 sads" x:Class="UiPath.Process" xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation" xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation" xmlns:sads="http://schemas.microsoft.com/netfx/2010/xaml/activities/debugger" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:ui="http://schemas.uipath.com/workflow/activities">
  <!--
    PlacementRecordBot — Main.xaml
    Writes selected candidate placement records to the mock ERP.

    INPUT  (Process Arguments — In):
      in_InterviewResultsJson : String  — JSON: {"results":[{"student_id":"...","name":"...","result":"Selected","package_lpa":12.5,"role":"SDE-1","feedback":""},...],"drive_id":"...","company_name":"..."}
      in_ERPBaseUrl           : String

    OUTPUT:
      out_RecordsWritten      : Int32
      out_SelectedCount       : Int32
  -->
  <x:Members>
    <x:Property Name="in_InterviewResultsJson" Type="InArgument(x:String)"/>
    <x:Property Name="in_ERPBaseUrl" Type="InArgument(x:String)"/>
    <x:Property Name="out_RecordsWritten" Type="OutArgument(x:Int32)"/>
    <x:Property Name="out_SelectedCount" Type="OutArgument(x:Int32)"/>
  </x:Members>

  <Sequence DisplayName="PlacementRecordBot — Write Placement Records" sap2010:WorkflowViewState.IdRef="Seq_Root">
    <Sequence.Variables>
      <Variable Name="resultsObj" Type="Newtonsoft.Json.Linq.JObject"/>
      <Variable Name="results" Type="Newtonsoft.Json.Linq.JArray"/>
      <Variable Name="driveId" Type="x:String"/>
      <Variable Name="companyName" Type="x:String"/>
      <Variable Name="recordsWritten" Type="x:Int32" Default="0"/>
      <Variable Name="selectedCount" Type="x:Int32" Default="0"/>
      <Variable Name="responseBody" Type="x:String"/>
      <Variable Name="statusCode" Type="x:Int32"/>
    </Sequence.Variables>

    <ui:LogMessage Level="Info" Message="[PlacementRecordBot] Starting placement record update."/>

    <ui:InvokeCode DisplayName="Parse Interview Results JSON">
      <ui:InvokeCode.Code>
        resultsObj = Newtonsoft.Json.Linq.JObject.Parse(in_InterviewResultsJson)
        results = CType(resultsObj("results"), Newtonsoft.Json.Linq.JArray)
        driveId = resultsObj("drive_id").ToString()
        companyName = resultsObj("company_name").ToString()
      </ui:InvokeCode.Code>
    </ui:InvokeCode>

    <ForEach x:TypeArguments="Newtonsoft.Json.Linq.JToken" DisplayName="For Each Candidate Result" Values="[results]">
      <ActivityAction x:TypeArguments="Newtonsoft.Json.Linq.JToken">
        <ActivityAction.Argument>
          <DelegateInArgument Name="resultToken"/>
        </ActivityAction.Argument>
        <Sequence DisplayName="Record Selected Candidate">
          <Sequence.Variables>
            <Variable Name="candidate" Type="Newtonsoft.Json.Linq.JObject"/>
            <Variable Name="isSelected" Type="x:Boolean"/>
            <Variable Name="payload" Type="x:String"/>
          </Sequence.Variables>

          <ui:InvokeCode DisplayName="Check if Selected">
            <ui:InvokeCode.Code>
              candidate = CType(resultToken, Newtonsoft.Json.Linq.JObject)
              isSelected = candidate("result").ToString().Equals("Selected", StringComparison.OrdinalIgnoreCase)
            </ui:InvokeCode.Code>
          </ui:InvokeCode>

          <If DisplayName="Only Record Selected Candidates" Condition="[isSelected]">
            <If.Then>
              <Sequence>
                <ui:InvokeCode DisplayName="Build Placement Record Payload">
                  <ui:InvokeCode.Code>
                    Dim record = New Newtonsoft.Json.Linq.JObject()
                    record("drive_id") = driveId
                    record("company_name") = companyName
                    record("role") = If(candidate("role") IsNot Nothing, candidate("role").ToString(), "Not Specified")
                    record("package_lpa") = If(candidate("package_lpa") IsNot Nothing, CDbl(candidate("package_lpa").ToString()), 0.0)
                    record("student_id") = candidate("student_id").ToString()
                    record("student_name") = candidate("name").ToString()
                    record("status") = "OFFER_ACCEPTED"
                    payload = record.ToString(Newtonsoft.Json.Formatting.None)
                    selectedCount += 1
                  </ui:InvokeCode.Code>
                </ui:InvokeCode>

                <TryCatch DisplayName="POST to ERP /placements/record">
                  <TryCatch.Try>
                    <Sequence>
                      <ui:HTTPRequest DisplayName="POST Placement Record"
                                      Endpoint="[in_ERPBaseUrl.TrimEnd('/') + '/placements/record']"
                                      Method="POST"
                                      Body="[payload]"
                                      BodyFormat="application/json"
                                      Response="[responseBody]"
                                      StatusCode="[statusCode]"
                                      TimeoutMS="15000"
                                      AcceptFormat="JSON"/>
                      <Assign>
                        <Assign.To><OutArgument x:TypeArguments="x:Int32">[recordsWritten]</OutArgument></Assign.To>
                        <Assign.Value><InArgument x:TypeArguments="x:Int32">[recordsWritten + 1]</InArgument></Assign.Value>
                      </Assign>
                      <ui:LogMessage Level="Info" Message="{'[PlacementRecordBot] Recorded: ' + candidate('name').ToString() + ' at ' + companyName}"/>
                    </Sequence>
                  </TryCatch.Try>
                  <TryCatch.Catches>
                    <Catch x:TypeArguments="x:Exception">
                      <ActivityAction x:TypeArguments="x:Exception">
                        <ActivityAction.Argument><DelegateInArgument Name="recEx"/></ActivityAction.Argument>
                        <ui:LogMessage Level="Error" Message="{'[PlacementRecordBot] Failed to record ' + candidate('name').ToString() + ': ' + recEx.Message}"/>
                      </ActivityAction>
                    </Catch>
                  </TryCatch.Catches>
                </TryCatch>
              </Sequence>
            </If.Then>
          </If>
        </Sequence>
      </ActivityAction>
    </ForEach>

    <Assign>
      <Assign.To><OutArgument x:TypeArguments="x:Int32">[out_RecordsWritten]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:Int32">[recordsWritten]</InArgument></Assign.Value>
    </Assign>
    <Assign>
      <Assign.To><OutArgument x:TypeArguments="x:Int32">[out_SelectedCount]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:Int32">[selectedCount]</InArgument></Assign.Value>
    </Assign>

    <ui:LogMessage Level="Info" Message="{'[PlacementRecordBot] Done. Records written: ' + recordsWritten.ToString() + ' | Selected: ' + selectedCount.ToString()}"/>
  </Sequence>
</Activity>
